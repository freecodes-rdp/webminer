#!/bin/bash

# 1. Configuration
URL="https://votre-adresse.com"
INTERVAL=150  # 15 minutes (900 secondes)
export DISPLAY=:1  # Vérifie bien ton numéro avec 'echo $DISPLAY'

echo "Démarrage du rafraîchissement forcé sur $DISPLAY..."

while true; do
    # On demande à Firefox d'ouvrir l'URL. 
    # S'il est déjà ouvert, Firefox rafraîchit l'onglet existant 
    # au lieu d'en ouvrir un nouveau (comportement par défaut).
    firefox "$URL" &
    
    echo "Ordre de recharge envoyé à $(date +%H:%M:%S)"
    
    # Attendre 15 minutes
    sleep $INTERVAL
done
