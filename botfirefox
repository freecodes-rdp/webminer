#!/bin/bash

# Configuration
URL="https://votre-site.com"
INTERVAL=150  # 15 minutes (900 secondes)

# Lancer Firefox si besoin
firefox "$URL" &
sleep 5

echo "Démarrage du cycle d'actualisation (toutes les 15 min)..."

while true; do
    # Attendre l'intervalle
    sleep $INTERVAL

    # 1. Trouver l'ID de la fenêtre Firefox
    WID=$(xdotool search --onlyvisible --class "firefox" | head -1)

    if [ -n "$WID" ]; then
        # 2. Mettre la fenêtre au premier plan (Indispensable)
        xdotool windowactivate --sync $WID
        
        # 3. Envoyer F5 avec un petit délai pour être sûr
        xdotool key --clearmodifiers F5
        
        echo "Page actualisée à $(date +%H:%M:%S)"
    else
        echo "Erreur : Fenêtre Firefox introuvable."
    fi
done
