#!/bin/bash

# --- CONFIG ---
URL="https://console.cloud.google.com/welcome/new?hl=fr&pli=1&cloudshell=true"
INTERVAL=150 # 15 minutes
PROFILE_NAME="refresh_profile"

# 1. Créer le profil s'il n'existe pas (une seule fois)
firefox -CreateProfile "$PROFILE_NAME" 2>/dev/null

echo "Démarrage du cycle sur le DISPLAY $DISPLAY..."

# 2. Premier lancement
firefox -P "$PROFILE_NAME" "$URL" &
sleep 10

while true; do
    sleep $INTERVAL
    
    # 3. Commande magique : si Firefox tourne déjà sur ce profil, 
    # le relancer avec l'URL force l'actualisation de l'onglet actif.
    firefox -P "$PROFILE_NAME" -new-window "$URL" &
    
    # Optionnel : Fermer l'ancien onglet pour éviter d'en avoir 1000
    # On attend 5s que le nouveau charge et on simule un Ctrl+W
    sleep 5
    WID=$(xdotool search --class "firefox" | tail -1)
    xdotool windowactivate --sync $WID key ctrl+w
    
    echo "Actualisé à $(date +%H:%M:%S)"
done
