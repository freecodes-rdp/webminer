#!/bin/bash

# --- CONFIGURATION ---
URL="https://console.cloud.google.com/welcome/new?hl=fr&pli=1&cloudshell=true"
INTERVAL=150 # 15 minutes
# Récupération automatique du DISPLAY si non défini
[[ -z "$DISPLAY" ]] && export DISPLAY=:1

echo "Lancement du rafraîchissement forcé sur $DISPLAY..."

while true; do
    # 1. On ferme Firefox proprement (ou violemment s'il bloque)
    pkill -f firefox
    sleep 2
    
    # 2. On nettoie les fichiers de verrouillage au cas où
    rm -rf ~/.mozilla/firefox/*.default-release/parent.lock 2>/dev/null

    # 3. On relance Firefox avec l'URL
    # --new-instance force le démarrage même si un processus fantôme existe
    firefox --new-instance "$URL" &
    
    echo "Relancé à $(date +%H:%M:%S)"
    
    # 4. Attente
    sleep $INTERVAL
done
