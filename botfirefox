#!/bin/bash

# URL ou chemin du fichier à ouvrir (optionnel si déjà ouvert)
URL="https://console.cloud.google.com/welcome/new?hl=fr&pli=1&cloudshell=true"

# Ouvrir Firefox si ce n'est pas déjà fait
firefox "$URL" &

# Boucle infinie
while true; do
    # Attendre 15 minutes (900 secondes)
    sleep 900
    
    # Cherche la fenêtre Firefox et envoie la touche F5
    xdotool search --onlyvisible --name "Mozilla Firefox" key F5
    
    echo "Page actualisée à $(date)"
done
