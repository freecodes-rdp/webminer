#!/bin/bash

# 1. Configuration
URL="https://votre-site.com"
INTERVAL=150  # 15 minutes en secondes

# 2. Lancer Firefox si non présent (ou simplement s'assurer qu'il est ouvert)
firefox "$URL" &
sleep 5 # Attendre que Firefox démarre

echo "Surveillance active : Actualisation toutes les 15 min..."

# 3. Boucle d'actualisation
while true; do
    sleep $INTERVAL
    
    # Cherche toutes les fenêtres de classe "firefox" et leur envoie F5
    WIDS=$(xdotool search --class "firefox")
    
    for WID in $WIDS; do
        # On tente d'envoyer la touche sans forcément voler le focus (moins intrusif)
        xdotool key --window "$WID" F5
    done
    
    echo "Actualisé à $(date +%H:%M:%S)"
done
